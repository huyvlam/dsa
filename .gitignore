# Exclude files
*.class
*.log
*.tmp
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
dependency-reduced-pom.xml


# Exclude directories
build/
dist/
out/
lib/
bin/
core/
node_modules/
target/


# Exclude system generated files
# MacOS
.DS_Store
.directory

# Maven
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# Window
Thumbs.db

# Eclipse
.project
.classpath


# Exclude editor configuration files
.vscode/
.idea/
.idea_modules/
*.iml
*.ipr
*.iws


# Exclude environment variable files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
config.json


# Exclude specific files within a particular folder
logs/*.log


# Exclude Mobile Tools for Java (J2ME)
.mtj.tmp/


# Exclude virtual machine crash logs
hs_err_pid*
replay_pid*


# Negation: Re-include a specific file that would otherwise be ignored
# (Note: parent directory must also not be ignored)
!/dist/important.file
